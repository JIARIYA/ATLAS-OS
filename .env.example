# Copy to .env and fill in. Never commit the real .env.

# Local dev (SQLite). For Postgres (e.g. Vercel/Neon), set provider="postgresql"
# in prisma/schema.prisma and use a postgres:// URL here.
DATABASE_URL="file:./dev.db"

# Sign session JWTs. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Optional: where uploaded files are written (defaults to ./.uploads).
# Point this at a persistent volume in production (e.g. /data/uploads).
# UPLOADS_DIR="/data/uploads"
