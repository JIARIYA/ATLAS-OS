// Atlas OS — data model for the outcome spine.
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  passwordHash   String
  createdAt      DateTime     @default(now())
  // Intention banner
  todayIntention String?
  intentionDate  DateTime?
  // Capacity (mirrors Profile — kept here for fast dashboard queries)
  deepWorkHours  Int          @default(4)
  totalWorkHours Int          @default(8)
  workdays       String       @default("1,2,3,4,5")
  goals          Goal[]
  projects       Project[]
  tasks          Task[]
  events         Event[]
  reviews        Review[]
  members        Member[]
  teams          Team[]
  domains        Domain[]
  attachments    Attachment[]
  profile        Profile?
  domainGoals    DomainGoal[]
  commitments    Commitment[]
}

model Team {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#6366f1")
  order     Int      @default(0)
  members   Member[]
  createdAt DateTime @default(now())

  @@index([userId])
}

model Attachment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String
  size      Int
  path      String
  createdAt DateTime @default(now())

  @@index([taskId])
}

model Member {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#3b82f6")
  isSelf    Boolean  @default(false)
  order     Int      @default(0)
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id])
  tasks     Task[]   @relation("Responsible")
  createdAt DateTime @default(now())

  @@index([userId])
}

model Domain {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  key         String
  name        String
  color       String
  order       Int          @default(0)
  goals       Goal[]
  projects    Project[]
  tasks       Task[]
  events      Event[]
  domainGoals DomainGoal[]

  @@unique([userId, key])
  @@index([userId])
}

model Goal {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  horizon      String    @default("annual")
  importance   Int       @default(3)
  metric       String?
  unit         String?
  targetValue  Float?
  currentValue Float     @default(0)
  startValue   Float     @default(0)
  targetDate   DateTime?
  status       String    @default("active")
  domainId     String?
  domain       Domain?   @relation(fields: [domainId], references: [id])
  parentId     String?
  parent       Goal?     @relation("GoalLadder", fields: [parentId], references: [id])
  children     Goal[]    @relation("GoalLadder")
  projects     Project[]
  tasks        Task[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model Project {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  objective       String?
  successCriteria String?
  status          String    @default("active")
  notes           String?
  targetDate      DateTime?
  domainId        String?
  domain          Domain?   @relation(fields: [domainId], references: [id])
  goalId          String?
  goal            Goal?     @relation(fields: [goalId], references: [id])
  tasks           Task[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}

model Task {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  status            String       @default("new")
  type              String       @default("operational")
  color             String?
  // Priority inputs
  impact            Int          @default(3)
  urgency           Int          @default(3)
  effortHours       Float        @default(1)
  energy            String       @default("medium")
  energyType        String       @default("mental")
  // Scheduling / execution
  startDate         DateTime?
  dueDate           DateTime?
  plannedDate       DateTime?
  scheduledStart    DateTime?
  scheduledEnd      DateTime?
  progress          Int          @default(0)
  actualHours       Float?
  completedAt       DateTime?
  // Recurrence
  recurrence        String? // "daily" | "weekly" | "monthly"
  recurrenceEndDate DateTime?
  // Subtasks (1-level nesting only)
  parentTaskId      String?
  parent            Task?        @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subtasks          Task[]       @relation("Subtasks")
  // Time tracking
  trackedSeconds    Int          @default(0)
  timerStartedAt    DateTime?
  // Strategic links
  domainId          String?
  domain            Domain?      @relation(fields: [domainId], references: [id])
  projectId         String?
  project           Project?     @relation(fields: [projectId], references: [id])
  goalId            String?
  goal              Goal?        @relation(fields: [goalId], references: [id])
  responsibleId     String?
  responsible       Member?      @relation("Responsible", fields: [responsibleId], references: [id])
  attachments       Attachment[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([userId])
  @@index([parentTaskId])
}

model Profile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String   @default("You")
  deepWorkHoursPerDay Float    @default(4)
  totalHoursPerDay    Float    @default(8)
  workdays            String   @default("1,2,3,4,5")
  updatedAt           DateTime @updatedAt
}

model Event {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  kind      String   @default("focus")
  start     DateTime
  end       DateTime
  domainId  String?
  domain    Domain?  @relation(fields: [domainId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Review {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  energy      Int?
  wins        String?
  blockers    String?
  notes       String?
  createdAt   DateTime     @default(now())
  commitments Commitment[]

  @@index([userId])
}

model DomainGoal {
  id         String    @id @default(cuid())
  title      String
  targetDate DateTime?
  domainId   String
  domain     Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([domainId])
  @@index([userId])
}

model Commitment {
  id             String   @id @default(cuid())
  text           String
  date           DateTime
  resolved       Boolean  @default(false)
  sourceReviewId String?
  sourceReview   Review?  @relation(fields: [sourceReviewId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([userId])
}
